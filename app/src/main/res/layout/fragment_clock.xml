<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="20dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reloj"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnBackground" />

            <ImageButton
                android:id="@+id/btn_toggle_theme"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_round_btn"
                android:padding="10dp"
                android:src="@drawable/ic_moon"
                app:tint="?attr/colorOnBackground"
                android:contentDescription="Cambiar tema"
                android:layout_marginEnd="8dp" />

            <ImageButton
                android:id="@+id/btn_toggle_view"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_round_btn"
                android:padding="10dp"
                android:src="@drawable/ic_digital"
                app:tint="@color/ios_blue"
                android:contentDescription="Vista analógica/digital" />
        </LinearLayout>

        <!-- Clock Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="36dp"
                android:paddingHorizontal="24dp">

                <com.example.relojmejorado.AnalogClockView
                    android:id="@+id/analog_clock"
                    android:layout_width="260dp"
                    android:layout_height="260dp" />

                <TextView
                    android:id="@+id/tv_digital_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12:00:00 AM"
                    android:textSize="48sp"
                    android:fontFamily="sans-serif-light"
                    android:letterSpacing="-0.02"
                    android:textColor="?attr/colorOnSurface"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Lunes, 01 Enero 2024"
                    android:textSize="15sp"
                    android:textColor="@color/ios_secondary_label" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>

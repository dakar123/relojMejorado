<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="20dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cronómetro"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnBackground" />

            <ImageButton
                android:id="@+id/btn_toggle_view_sw"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_round_btn"
                android:padding="10dp"
                android:src="@drawable/ic_digital"
                app:tint="@color/ios_blue"
                android:contentDescription="Vista analógica/digital" />
        </LinearLayout>

        <!-- Display card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="28dp">

                <com.example.relojmejorado.AnalogClockView
                    android:id="@+id/analog_stopwatch"
                    android:layout_width="220dp"
                    android:layout_height="220dp" />

                <TextView
                    android:id="@+id/tv_digital_stopwatch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00.00"
                    android:textSize="58sp"
                    android:fontFamily="sans-serif-light"
                    android:letterSpacing="-0.02"
                    android:textColor="?attr/colorOnSurface"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <Button
                android:id="@+id/btn_reset"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Reiniciar"
                android:textSize="16sp"
                android:backgroundTint="@color/btn_secondary"
                android:textColor="?attr/colorOnBackground"
                style="@style/Widget.Material3.Button" />

            <Button
                android:id="@+id/btn_start_stop"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:text="Iniciar"
                android:textSize="16sp"
                android:backgroundTint="@color/ios_blue"
                style="@style/Widget.Material3.Button" />
        </LinearLayout>

        <!-- Save button -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:text="Guardar tiempo"
            android:textSize="16sp"
            android:backgroundTint="@color/ios_green"
            style="@style/Widget.Material3.Button"
            android:visibility="gone" />

        <!-- Saved times section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tiempos guardados"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnBackground" />

            <ImageButton
                android:id="@+id/btn_toggle_sort"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_round_btn"
                android:padding="8dp"
                android:src="@drawable/ic_sort_desc"
                app:tint="@color/ios_blue"
                android:contentDescription="Cambiar orden" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_saved_times"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
